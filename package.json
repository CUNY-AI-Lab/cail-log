{
  "name": "@cuny-ai-lab/cail-log",
  "version": "0.3.0",
  "description": "The pre-release CAIL operational event primitive: typed event contracts, trusted fleet attribution, privacy-safe diagnostics, and explicit structured sinks.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "DESIGN.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check:dist": "bun run build && git diff --exit-code -- dist",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run build",
    "prepare": "bun run build",
    "verify": "bun run build && bun test && bun run typecheck && bun pm pack --dry-run --ignore-scripts"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CUNY-AI-Lab/cail-log.git"
  }
}
